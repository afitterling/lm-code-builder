"""llm-code — Claude Code-style local CLI backed by LM Studio.

Start LM Studio's local server with a tool-calling model loaded, then run
`./llm-code` from the folder you want code written in.

Flags:
  --yes / -y   auto-approve every run_bash call (skip the y/N prompt)

Env vars:
  LM_BASE      base URL of the OpenAI-compatible server
               (default: http://localhost:1234/v1)
  LM_MODEL     model id to use (default: first model returned by /v1/models)
  LLM_CODE_YES if set to 1/true/yes, start in auto-yes mode
"""

import argparse
import json
import os
import subprocess
import sys
import urllib.error
import urllib.request
from pathlib import Path

try:
    from prompt_toolkit import PromptSession
    from prompt_toolkit.auto_suggest import AutoSuggestFromHistory
    from prompt_toolkit.formatted_text import HTML
    from prompt_toolkit.history import FileHistory
    from prompt_toolkit.styles import Style as PTStyle
except ImportError:
    sys.exit("Missing dependency. Run: pip install prompt_toolkit rich")

try:
    from rich.console import Console
    from rich.markdown import Markdown
    from rich.panel import Panel
    from rich.prompt import Confirm
    from rich.text import Text
except ImportError:
    sys.exit("Missing dependency. Run: pip install prompt_toolkit rich")

LM_BASE = os.environ.get("LM_BASE", "http://localhost:1234/v1").rstrip("/")
LM_MODEL = os.environ.get("LM_MODEL", "")
WORKDIR = Path.cwd().resolve()
HISTORY_FILE = Path.home() / ".llm-code_history"
MAX_TOOL_ROUNDS = 25

console = Console()
_current_model = "?"
_auto_yes = os.environ.get("LLM_CODE_YES", "").lower() in ("1", "true", "yes", "y")

TOOLS = [
    {
        "type": "function",
        "function": {
            "name": "read_file",
            "description": "Read a UTF-8 text file inside the working directory.",
            "parameters": {
                "type": "object",
                "properties": {"path": {"type": "string"}},
                "required": ["path"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "write_file",
            "description": "Create or overwrite a file with the given content. "
                           "Pass the full file contents — there is no patch tool.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {"type": "string"},
                    "content": {"type": "string"},
                },
                "required": ["path", "content"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "list_files",
            "description": "List entries in a directory (default '.').",
            "parameters": {
                "type": "object",
                "properties": {"path": {"type": "string"}},
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "run_bash",
            "description": "Run a shell command in the working directory. "
                           "The user is prompted to confirm before it runs.",
            "parameters": {
                "type": "object",
                "properties": {"command": {"type": "string"}},
                "required": ["command"],
            },
        },
    },
]


def safe_path(p: str) -> Path:
    target = (WORKDIR / p).resolve()
    if target != WORKDIR and WORKDIR not in target.parents:
        raise ValueError(f"path escapes working directory: {p}")
    return target


def tool_read_file(path: str) -> str:
    return safe_path(path).read_text(encoding="utf-8", errors="replace")


def tool_write_file(path: str, content: str) -> str:
    target = safe_path(path)
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(content, encoding="utf-8")
    return f"wrote {len(content)} bytes to {path}"


def tool_list_files(path: str = ".") -> str:
    p = safe_path(path)
    if not p.is_dir():
        return f"not a directory: {path}"
    return "\n".join(
        e.name + ("/" if e.is_dir() else "") for e in sorted(p.iterdir())
    ) or "(empty)"


def tool_run_bash(command: str) -> str:
    console.print(Text(f"  $ {command}", style="bold yellow"))
    if _auto_yes:
        console.print(Text("  auto-yes: running without prompt", style="dim italic"))
    else:
        try:
            ok = Confirm.ask("  run this command?", default=False, console=console)
        except (EOFError, KeyboardInterrupt):
            ok = False
        if not ok:
            return "user declined to run the command"
    proc = subprocess.run(
        command, shell=True, cwd=WORKDIR,
        capture_output=True, text=True, timeout=300,
    )
    out = (proc.stdout or "") + (proc.stderr or "")
    if len(out) > 8000:
        out = out[:4000] + "\n…[truncated]…\n" + out[-4000:]
    return f"exit={proc.returncode}\n{out}"


TOOL_IMPL = {
    "read_file": tool_read_file,
    "write_file": tool_write_file,
    "list_files": tool_list_files,
    "run_bash": tool_run_bash,
}


def http_json(method: str, url: str, payload=None, timeout=600):
    data = json.dumps(payload).encode() if payload is not None else None
    req = urllib.request.Request(
        url, data=data, method=method,
        headers={"Content-Type": "application/json"} if data else {},
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", "replace")
        raise RuntimeError(f"HTTP {e.code} from {url}: {body[:500]}") from None
    except urllib.error.URLError as e:
        raise RuntimeError(f"cannot reach {url}: {e.reason}") from None


def detect_model() -> str:
    if LM_MODEL:
        return LM_MODEL
    data = http_json("GET", f"{LM_BASE}/models", timeout=10)
    ids = [m["id"] for m in data.get("data", [])]
    if not ids:
        sys.exit("No models loaded in LM Studio — load one in the UI first.")
    return ids[0]


SYSTEM_PROMPT = (
    f"You are a coding assistant working inside the folder {WORKDIR}.\n"
    "You have tools: read_file, write_file, list_files, run_bash.\n"
    "When the user asks for code, write it directly into files with write_file.\n"
    "write_file always overwrites, so pass the complete file content.\n"
    "Stay inside the working directory. Keep chat replies short — the real\n"
    "output is the files you create. Stop calling tools once the task is done."
)


def render_args(args: dict) -> str:
    parts = []
    for k, v in args.items():
        s = repr(v)
        if len(s) > 60:
            s = s[:57] + "...'"
        parts.append(f"{k}={s}")
    return ", ".join(parts)


def show_banner(model: str) -> None:
    mode = ("auto-yes ON", "bold red") if _auto_yes else ("ask before bash", "bold green")
    body = Text.assemble(
        ("llm-code", "bold cyan"),
        ("  ·  ", "dim"),
        ("a local-LLM coding agent\n\n", "dim italic"),
        ("model: ", "dim"), (model, "bold green"), ("\n", ""),
        ("dir:   ", "dim"), (str(WORKDIR), "bold yellow"), ("\n", ""),
        ("mode:  ", "dim"), mode, ("\n\n", ""),
        ("commands: ", "dim"),
        ("/reset", "white"), ("  ", "dim"),
        ("/yes", "white"), ("  ", "dim"),
        ("/ask", "white"), ("  ", "dim"),
        ("/exit", "white"), ("  ", "dim"),
        ("Ctrl-D", "white"), ("\n", "dim"),
        ("tips: ", "dim"),
        ("↑/↓ history · Ctrl-R search · Tab autocomplete suggestions", "dim"),
    )
    console.print(Panel(body, border_style="cyan", padding=(0, 1)))


def show_assistant(content: str) -> None:
    content = (content or "").strip()
    if not content:
        return
    console.print(Panel(
        Markdown(content),
        title="[bold cyan]assistant[/bold cyan]",
        title_align="left",
        border_style="cyan",
        padding=(0, 1),
    ))


def show_tool_call(name: str, args: dict) -> None:
    console.print(
        Text("▸ ", style="bold magenta")
        + Text(name, style="bold magenta")
        + Text(f"({render_args(args)})", style="dim")
    )


def summarize_tool(name: str, args: dict, result: str) -> tuple[str, bool]:
    """One-line, human-readable summary of a tool call. Returns (text, ok)."""
    failed = result.startswith("ERROR")
    if name == "read_file":
        path = args.get("path", "?")
        if failed:
            return f"read failed · {path} · {result.removeprefix('ERROR: ')}", False
        lines = result.count("\n") + (0 if result.endswith("\n") or not result else 1)
        return f"read {len(result)} bytes · {lines} lines · {path}", True
    if name == "write_file":
        path = args.get("path", "?")
        content = args.get("content", "") or ""
        if failed:
            return f"write failed · {path} · {result.removeprefix('ERROR: ')}", False
        lines = content.count("\n") + (0 if content.endswith("\n") or not content else 1)
        return f"wrote {len(content)} bytes · {lines} lines · {path}", True
    if name == "list_files":
        path = args.get("path", ".")
        if failed:
            return f"list failed · {path} · {result.removeprefix('ERROR: ')}", False
        if result == "(empty)":
            return f"listed 0 entries · {path}", True
        n = result.count("\n") + 1
        return f"listed {n} entries · {path}", True
    if name == "run_bash":
        if result == "user declined to run the command":
            return "declined · command not run", False
        if failed:
            return f"bash failed · {result.removeprefix('ERROR: ')}", False
        first, _, rest = result.partition("\n")
        try:
            code = int(first.split("=", 1)[1])
        except (IndexError, ValueError):
            code = -1
        out_lines = rest.count("\n") + (0 if rest.endswith("\n") or not rest else 1)
        return f"exit={code} · {out_lines} output lines", code == 0
    return (result[:80] + ("…" if len(result) > 80 else "")), not failed


def show_tool_result(name: str, args: dict, result: str) -> None:
    summary, ok = summarize_tool(name, args, result)
    mark = Text("    ✓ ", style="bold green") if ok else Text("    ✗ ", style="bold red")
    console.print(mark + Text(summary, style="green" if ok else "red"))


def show_error(msg: str) -> None:
    console.print(Panel(
        Text(msg, style="red"),
        border_style="red",
        title="[bold red]error[/bold red]",
        title_align="left",
        padding=(0, 1),
    ))


def make_session() -> PromptSession:
    style = PTStyle.from_dict({
        "prompt": "ansicyan bold",
        "bottom-toolbar": "bg:#1f1f1f #aaaaaa",
        "bottom-toolbar.label": "bg:#1f1f1f #ffffff bold",
        "bottom-toolbar.value": "bg:#1f1f1f #5fd7ff",
        "bottom-toolbar.dir": "bg:#1f1f1f #ffaf5f",
        "bottom-toolbar.yes": "bg:#5f0000 #ffffff bold",
        "bottom-toolbar.ask": "bg:#1f1f1f #5fff5f",
    })

    def toolbar():
        if _auto_yes:
            mode_html = '<style class="bottom-toolbar.yes"> AUTO-YES </style>'
        else:
            mode_html = '<style class="bottom-toolbar.ask">ask</style>'
        return HTML(
            ' <style class="bottom-toolbar.label">llm-code</style>  '
            'model: <style class="bottom-toolbar.value">{model}</style>  '
            'dir: <style class="bottom-toolbar.dir">{dir}</style>  '
            'mode: {mode}  '
            '<style class="bottom-toolbar.label">/yes · /ask · /reset · /exit</style>'
            .format(model=_current_model, dir=str(WORKDIR), mode=mode_html)
        )

    return PromptSession(
        history=FileHistory(str(HISTORY_FILE)),
        auto_suggest=AutoSuggestFromHistory(),
        style=style,
        bottom_toolbar=toolbar,
        complete_while_typing=False,
        mouse_support=False,
    )


def agent_turn(model: str, messages: list) -> None:
    for _ in range(MAX_TOOL_ROUNDS):
        try:
            with console.status("[dim italic]thinking…[/dim italic]", spinner="dots"):
                resp = http_json("POST", f"{LM_BASE}/chat/completions", {
                    "model": model,
                    "messages": messages,
                    "tools": TOOLS,
                    "tool_choice": "auto",
                    "temperature": 0.2,
                    "stream": False,
                })
        except RuntimeError as e:
            show_error(str(e))
            return

        msg = resp["choices"][0]["message"]
        messages.append({
            "role": "assistant",
            "content": msg.get("content") or "",
            "tool_calls": msg.get("tool_calls") or [],
        })
        show_assistant(msg.get("content") or "")

        tool_calls = msg.get("tool_calls") or []
        if not tool_calls:
            return

        for call in tool_calls:
            name = call["function"]["name"]
            raw = call["function"].get("arguments") or "{}"
            try:
                args = json.loads(raw)
            except json.JSONDecodeError:
                args = {}
            show_tool_call(name, args)
            impl = TOOL_IMPL.get(name)
            try:
                result = impl(**args) if impl else f"unknown tool: {name}"
            except Exception as e:
                result = f"ERROR: {type(e).__name__}: {e}"
            show_tool_result(name, args, str(result))
            messages.append({
                "role": "tool",
                "tool_call_id": call.get("id", ""),
                "name": name,
                "content": str(result),
            })
    show_error("tool-call round limit reached")


EXIT_WORDS = {"/exit", "/quit", "exit", "quit", ":q"}


def main() -> None:
    global _current_model, _auto_yes

    parser = argparse.ArgumentParser(prog="llm-code", add_help=True)
    parser.add_argument(
        "-y", "--yes", action="store_true",
        help="auto-approve every run_bash call (skip the y/N prompt)",
    )
    args = parser.parse_args()
    if args.yes:
        _auto_yes = True

    try:
        _current_model = detect_model()
    except RuntimeError as e:
        show_error(str(e))
        sys.exit(1)

    show_banner(_current_model)
    session = make_session()
    prompt = HTML('<ansicyan><b>»</b></ansicyan> ')
    messages = [{"role": "system", "content": SYSTEM_PROMPT}]

    while True:
        try:
            user = session.prompt(prompt).strip()
        except (EOFError, KeyboardInterrupt):
            console.print()
            return
        if not user:
            continue
        if user.lower() in EXIT_WORDS:
            return
        if user == "/reset":
            messages = [{"role": "system", "content": SYSTEM_PROMPT}]
            console.print(Text("(history cleared)", style="dim italic"))
            continue
        if user in ("/yes", "/auto"):
            _auto_yes = True
            console.print(Text("auto-yes mode ON — bash runs without confirmation",
                               style="bold red"))
            continue
        if user in ("/ask", "/no", "/confirm"):
            _auto_yes = False
            console.print(Text("auto-yes mode OFF — bash will prompt for y/N",
                               style="bold green"))
            continue

        messages.append({"role": "user", "content": user})
        try:
            agent_turn(_current_model, messages)
        except Exception as e:
            show_error(f"{type(e).__name__}: {e}")
            messages.pop()


if __name__ == "__main__":
    main()
